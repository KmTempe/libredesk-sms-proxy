# Server
PORT=3400
NODE_ENV=development
DATA_DIR=./data
testphone=6900000000

# Trusted reverse-proxy domain (set this in production)
# Requests must arrive via this domain or from localhost.
# ALLOWED_DOMAIN=your-domain.example.com

# LibreDesk webhook secret (optional but recommended)
# LD_HOOKER_PASS=yourbase64secret

# SMSGate credentials
# SMSGATE_URL=http://192.168.1.100:8080
# SMSGATE_USER=
# SMSGATE_PASS=
