# Server
PORT=3400
NODE_ENV=development
DATA_DIR=./data
testphone=6900000000

# Trusted reverse-proxy domain (set this in production)
# Requests must arrive via this domain or from localhost.
ALLOWED_DOMAIN=your-domain.example.com

# SMSGate credentials
SMSGATE_URL=http://[IP_ADDRESS]:[port]
SMSGATE_USER=user
SMSGATE_PASS=pass
