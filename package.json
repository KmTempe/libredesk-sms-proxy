{
  "name": "libredesk-sms-proxy",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "npx concurrently \"npx nodemon server/index.js\" \"cd client && npm run dev\"",
    "build": "cd client && npm run build && cd .. && npm run build:copy",
    "build:copy": "node -e \"const fs=require('fs'); fs.rmSync('server/public',{recursive:true,force:true}); fs.mkdirSync('server/public',{recursive:true}); fs.cpSync('client/dist','server/public',{recursive:true});\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:client": "eslint client"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.0"
  }
}
